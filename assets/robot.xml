<mujoco model="simple_reacher">
  <compiler autolimits="true"/>
  <option timestep="0.01" gravity="0 0 -9.81"/>

  <worldbody>
    <light name="top" pos="0 0 2" dir="0 0 -1" diffuse=".8 .8 .8"/>
    <geom name="floor" type="plane" size="2 2 0.1" rgba=".8 .8 .8 1"/>

    <body name="base" pos="0 0 0.5">
      <geom type="cylinder" size="0.05 0.05" rgba=".4 .4 .8 1"/>
      <joint name="joint1" type="hinge" axis="0 0 1" range="-3.14 3.14"/>

      <body name="upper_arm" pos="0 0 0.1">
        <geom type="capsule" fromto="0 0 0 0.2 0 0" size="0.03" rgba=".6 .4 .2 1"/>
        <joint name="joint2" type="hinge" axis="0 1 0" range="-3.14 3.14"/>

        <body name="lower_arm" pos="0.2 0 0">
          <geom type="capsule" fromto="0 0 0 0.15 0 0" size="0.025" rgba=".6 .4 .2 1"/>
          <joint name="joint3" type="hinge" axis="0 1 0" range="-3.14 3.14"/>
          <site name="end_effector" pos="0.15 0 0" size="0.02" rgba="1 0 0 1"/>
        </body>
      </body>
    </body>

    <site name="target" pos="0.3 0.1 0.5" size="0.03" rgba="0 1 0 0.5"/>
    <geom name="hazard1" type="sphere" pos="0.15 0.15 0.5" size="0.08" rgba="1 0 0 0.3"/>
  </worldbody>

  <actuator>
    <motor joint="joint1" name="act1" ctrlrange="-1 1" gear="50"/>
    <motor joint="joint2" name="act2" ctrlrange="-1 1" gear="50"/>
    <motor joint="joint3" name="act3" ctrlrange="-1 1" gear="50"/>
  </actuator>
</mujoco>
